# GTM Agents — example environment configuration
#
# Copy this file to `.env` at the repo root and fill in real values:
#
#     cp .env.example .env
#
# `.env` is git-ignored. NEVER commit real secrets, tokens, or customer data.
# All values below are placeholders. Leave a variable blank/commented to use its
# in-code default (placeholders like `example-gcp-project`) or to disable the
# feature that depends on it.
#
# Not every agent needs every variable — see the per-agent READMEs
# (plg_upsell/README.md, bdr_agent/README.md) and CONTRIBUTING.md for details.

# =============================================================================
# Google Cloud / BigQuery / GCS   (required for anything that reads/writes data)
# =============================================================================
GCP_PROJECT=example-gcp-project
# Default dataset differs by component: bdr_agent -> "gtm_agents",
# plg_upsell scripts -> "analytics". Set per your warehouse.
BQ_DATASET=gtm_agents
GCS_ARTIFACT_BUCKET=example-artifacts-bucket
# Auth: EITHER paste a service-account JSON string here, OR leave blank and use
# Application Default Credentials (`gcloud auth application-default login`).
GCP_SERVICE_ACCOUNT_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# =============================================================================
# HubSpot   (required for CRM sync / writeback)
# =============================================================================
# Private app token. Any ONE of these names works; these are the accepted
# aliases (first non-empty wins): HUBSPOT_PRIVATE_APP_TOKEN, HUBSPOT_API_KEY,
# GENERAL_HUBSPOT_APP_TOKEN, HUBSPOT_ACCESS_TOKEN, BDR_AGENT_HUBSPOT_API_KEY.
HUBSPOT_PRIVATE_APP_TOKEN=
# Portal ID (used to build app.hubspot.com record links).
HUBSPOT_PORTAL_ID=000000000
# BDR_AGENT_HUBSPOT_PORTAL_ID=000000000

# =============================================================================
# Slack   (required to post digests / notifications)
# =============================================================================
# Preferred: bot token (uses chat.postMessage).
PLG_SLACK_BOT_TOKEN=
# Default channel ID for the PLG digest (override with --channel).
SLACK_CHANNEL=
# Optional fallback if no bot token is set.
HUBSPOT_SLACK_WEBHOOK=
# Optional: Slack user/DM ID for Tier 2 approvals.
# TIER2_APPROVAL_SLACK_DM=
# BDR agent Slack (falls back to SLACK_BOT_TOKEN if unset):
# BDR_AGENT_SLACK_BOT_TOKEN=
# BDR_AGENT_OUTREACH_COMPOSER_SLACK_CHANNEL_ID=

# =============================================================================
# PLG routing, owners & sequences (HubSpot)   (optional; Dagster lead sync)
# =============================================================================
# HubSpot owner IDs for lead routing.
# PLG_BDR_OWNER_A=
# PLG_BDR_OWNER_B=
# PLG_AE_OWNER_1=
# PLG_AE_OWNER_2=
# PLG_AE_OWNER_3=
# PLG_AE_OWNER_4=
# HubSpot workflow IDs (Automation > Workflows; ID is in the URL).
# PLG_ACCOUNT_ROUTING_WORKFLOW_ID=
# PLG_CONTACT_ROUTING_WORKFLOW_ID=
# HubSpot sequence IDs (CRM > Sequences; ID is in the URL).
# PLG_TIER1_SEQUENCE_ID=
# PLG_TIER2_SEQUENCE_ID=
# PLG_PRODUCT_QUALIFIED_SEQUENCE_ID=
# PLG_PRODUCT_QUALIFIED_SEQUENCE_NAME=Tier 1 PQL
# HubSpot custom object type for Leads (default "leads").
# PLG_HUBSPOT_LEAD_OBJECT_TYPE=leads
# Optional prompt-share URL that renders the "Draft outreach" link on champion cards.
# PLG_OUTREACH_PROMPT_URL=

# =============================================================================
# Enrichment / research integrations   (optional)
# =============================================================================
# Exa search API key (BDR company research, Tier 2).
# BDR_AGENT_EXA_API_KEY=
# Apollo enrichment API key (accepts APOLLO_API_ENRICHMENT_API_KEY, APOLLO_API_KEY, Apollo_API_Key).
# APOLLO_API_ENRICHMENT_API_KEY=
# Metabase (dashboard builder script).
# METABASE_URL=https://metabase.example.com
# METABASE_API_KEY=

# =============================================================================
# BDR agent behavior   (optional; safe defaults are read-only / dry-run)
# =============================================================================
# Set to "true" to allow the outreach composer to write hooks back to HubSpot.
# BDR_AGENT_ALLOW_HUBSPOT_WRITEBACK=false
# Delivery mode: dry_run | slack | hubspot | both.
# BDR_AGENT_OUTREACH_COMPOSER_DELIVERY_MODE=dry_run
# Stage-completion handoff webhook (chains company_research -> outreach composer).
# BDR_AGENT_STAGE_COMPLETION_WEBHOOK_URL=
# BDR_AGENT_STAGE_COMPLETION_WEBHOOK_SECRET=

# =============================================================================
# Oz cloud runtime   (auto-injected when running as an Oz cloud agent)
# =============================================================================
# These are normally provided by the Oz runtime; leave unset for local runs.
# OZ_RUN_ID=
# WARP_SERVER_ROOT_URL=
# WARP_FOCUS_URL=
# OZ_CREDITS_USED=
# BDR_AGENT_OZ_DEV_ENVIRONMENT_ID=example-oz-environment-id
# WARP_API_KEY=
